# AgeBand — local environment configuration
# Copy to .env and adjust, or `make setup-env`. Values here match the
# Dockerfile defaults; override for your local vLLM / OpenAI-compatible
# endpoint.

# vLLM / OpenAI-compatible model endpoint
LOCAL_API_BASE=http://localhost:8000/v1
LOCAL_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_API_KEY=EMPTY

# Skip the AMD ROCm/vLLM reachability check on startup (useful for local dev
# without a GPU)
SKIP_AMD_CHECK=true

# Planner / gate tuning
PLANNER_MAX_ITERATIONS=8
GATE_CONFIDENCE_THRESHOLD=0.85
GATE_MIN_TURNS=2

LOG_LEVEL=INFO
