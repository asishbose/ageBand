# AgeBand — local environment configuration
# Copy to .env and adjust, or `make setup-env`. Values here match the
# Dockerfile defaults; override for your local vLLM / OpenAI-compatible
# endpoint.

# vLLM / OpenAI-compatible model endpoint
LOCAL_API_BASE=http://localhost:8000/v1
# Fallback model used when EXTRACTOR_MODEL / ESTIMATOR_MODEL are not set.
LOCAL_MODEL=google/gemma-3-4b-it
LOCAL_API_KEY=EMPTY

# Per-delegate model overrides — leave empty to use LOCAL_MODEL for both.
# Signal-extraction delegate (M2): small model for low-latency cue detection.
EXTRACTOR_MODEL=google/gemma-3-4b-it
# Age-band estimation delegate (M4): larger model for reasoning-rich estimation.
# model_comparison.md: gemma4:31b correctly abstained on ambiguous_adult where
# smaller models over-tightened. The estimator gets the larger model.
ESTIMATOR_MODEL=google/gemma-3-27b-it

# Skip the AMD ROCm/vLLM reachability check on startup (useful for local dev
# without a GPU)
SKIP_AMD_CHECK=true

# Planner / gate tuning
PLANNER_MAX_ITERATIONS=8
GATE_CONFIDENCE_THRESHOLD=0.85
GATE_MIN_TURNS=2

LOG_LEVEL=INFO

# Phase 5: guided decoding (vLLM guided_decoding_backend, requires >= 0.4.0).
# Set to 1 to constrain M4 estimator output to the JSON schema.
# Leave empty to disable (safe for Ollama and endpoints without guided decoding).
GUIDED_DECODING_ENABLED=

# Phase 5: cross-turn persona consistency via embeddings.
# Set EMBEDDING_MODEL to a small embedding model (e.g. BAAI/bge-small-en-v1.5).
# Leave empty to disable — the pipeline runs offline without embeddings.
EMBEDDING_MODEL=
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
