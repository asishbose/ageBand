*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# Secrets / captured certs
*.pem
*-key.json
secrets.env
.env

# Notebook runtime scratch
*.log
*.pid
__pycache__/
.ipynb_checkpoints/
