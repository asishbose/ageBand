<mxfile host="app.diagrams.net" agent="ageband" version="24.0.0">
  <diagram name="Architecture" id="ageband-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="a-title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A1A2E;" value="AgeBand — passive age-band inference from chat, driving graduated safety" vertex="1">
          <mxGeometry x="60" y="20" width="1320" height="34" as="geometry" />
        </mxCell>
        <mxCell id="a-sub" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#555;" value="Bands not precise ages &amp;middot; graduated not hard blocks &amp;middot; ask-don't-assume &amp;middot; ephemeral (only CONFIRMED age persists) &amp;middot; step-up is the real backstop" vertex="1">
          <mxGeometry x="60" y="54" width="1320" height="24" as="geometry" />
        </mxCell>
        <mxCell id="a-runtime" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7EE;strokeColor=#3D9E63;verticalAlign=top;fontSize=13;fontStyle=1;align=center;fontColor=#1E6B3A;" value="Inside the operator's environment — on-prem (AMD)" vertex="1">
          <mxGeometry x="60" y="100" width="1320" height="520" as="geometry" />
        </mxCell>
        <mxCell id="a-turn" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="User turn&lt;br&gt;(async fork —&lt;br&gt;not in reply path)" vertex="1">
          <mxGeometry x="90" y="160" width="150" height="90" as="geometry" />
        </mxCell>
        <mxCell id="a-gate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Cheap gate&lt;br&gt;(state check, NOT LLM)&lt;br&gt;&lt;br&gt;settled → reuse posture&lt;br&gt;tripwire: contradicting&lt;br&gt;cues → re-analyze" vertex="1">
          <mxGeometry x="270" y="150" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a-extract" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="Signal extraction&lt;br&gt;(1 LLM pass)&lt;br&gt;&lt;br&gt;vocab · topics ·&lt;br&gt;disclosure · style&lt;br&gt;(reading-level = tool)" vertex="1">
          <mxGeometry x="510" y="150" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a-evid" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" value="Evidence store&lt;br&gt;&lt;br&gt;session-scoped,&lt;br&gt;ephemeral · corroborates&lt;br&gt;across turns" vertex="1">
          <mxGeometry x="750" y="150" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a-infer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Age-band inference&lt;br&gt;&lt;br&gt;LLM proposes band + cues;&lt;br&gt;confidence = DETERMINISTIC&lt;br&gt;from evidence (+ nudge)&lt;br&gt;(can say 'unknown')" vertex="1">
          <mxGeometry x="990" y="150" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a-policy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Policy engine&lt;br&gt;(deterministic)&lt;br&gt;&lt;br&gt;band + confidence →&lt;br&gt;safety_posture&lt;br&gt;(graduated, tunable)" vertex="1">
          <mxGeometry x="1230" y="300" width="130" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a-apply" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Emit safety_posture&lt;br&gt;{level, flags}&lt;br&gt;&lt;br&gt;HOST assistant honors it&lt;br&gt;(AgeBand never touches&lt;br&gt;the model / reply path)" vertex="1">
          <mxGeometry x="850" y="360" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a-stepup" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Step-up (high-impact +&lt;br&gt;high-conf) — SYNC:&lt;br&gt;blocks that one reply&lt;br&gt;&lt;br&gt;confirm age · restrict ·&lt;br&gt;hand off" vertex="1">
          <mxGeometry x="1150" y="470" width="230" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a-confirm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" value="Explicit CONFIRMED age&lt;br&gt;overrides · may persist&lt;br&gt;(inferred never persists)" vertex="1">
          <mxGeometry x="850" y="520" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a-out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;align=center;verticalAlign=middle;" value="Output: band + confidence + posture&lt;br&gt;ephemeral · minimal · NOT a profile" vertex="1">
          <mxGeometry x="340" y="400" width="400" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a-amd" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#1E6B3A;" value="Self-hosted on AMD GPUs (operator's hardware) — inferring 'likely a minor' from private chat cannot leave the boundary" vertex="1">
          <mxGeometry x="60" y="636" width="1320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ae0" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="a-turn" target="a-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae1" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="a-gate" target="a-extract" value="analyze">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae2" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#d79b00;dashed=1;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="a-extract" target="a-evid" value="cues">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae3" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="a-evid" target="a-infer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae4" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="a-infer" target="a-policy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae4b" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#6c8ebf;dashed=1;endArrow=block;exitX=0.5;exitY=1;entryX=0;entryY=0.4;" edge="1" source="a-gate" target="a-policy" value="settled → reuse">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="370" y="300" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ae5" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#82b366;endArrow=block;exitX=0.5;exitY=1;entryX=1;entryY=0.4;" edge="1" source="a-policy" target="a-apply" value="apply">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1110" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ae6" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#b85450;endArrow=block;exitX=0.5;exitY=1;entryX=1;entryY=0.2;" edge="1" source="a-policy" target="a-stepup" value="high-impact">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1295" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ae7" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="a-stepup" target="a-confirm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae8" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#9673a6;dashed=1;endArrow=block;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" source="a-confirm" target="a-policy" value="override">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1295" y="560" />
