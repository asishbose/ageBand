  </diagram>
  <diagram name="UML (OpenAI Agents SDK)" id="ageband-uml">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="2700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="u-main" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=18;fontStyle=1;align=center;" value="AgeBand — Age-Band Inference &amp;amp; Graduated Safety (OpenAI Agents SDK)" vertex="1">
          <mxGeometry x="40" y="70" width="1720" height="2560" as="geometry" />
        </mxCell>
        <mxCell id="u-sub" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#7A4A00;" value="Async per-turn signal (not in the reply path) &amp;middot; cheap gate short-circuits settled sessions &amp;middot; band + deterministic confidence &amp;middot; safety_posture the host honors &amp;middot; step-up = backstop &amp;middot; on-prem AMD" vertex="1">
          <mxGeometry x="70" y="110" width="1180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="u-legend" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; Sequential (handoff)&lt;br&gt;&lt;font color='#d79b00'&gt;&lt;b&gt;&amp;#9472;&amp;#9472;&lt;/b&gt;&lt;/font&gt; Tool call&lt;br&gt;&lt;font color='#82b366'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; Apply safety (low/med conf)&lt;br&gt;&lt;font color='#b85450'&gt;&lt;b&gt;&amp;#9472;&amp;#9472;&lt;/b&gt;&lt;/font&gt; Step-up (high impact)&lt;br&gt;&lt;font color='#9673a6'&gt;&lt;b&gt;- - -&lt;/b&gt;&lt;/font&gt; Confirmation override&lt;br&gt;&lt;font color='#6c8ebf'&gt;&lt;b&gt;- - -&lt;/b&gt;&lt;/font&gt; Loop to next turn" vertex="1">
          <mxGeometry x="1300" y="100" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="u-p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Phase 1: Async Turn Hook, Cheap Gate &amp;amp; Orchestrator (Runner)" vertex="1">
          <mxGeometry x="70" y="270" width="1660" height="330" as="geometry" />
        </mxCell>
        <mxCell id="u-hook" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Turn Hook + Cheap Gate&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; Fires on each user turn as an&lt;br&gt;&amp;nbsp; ASYNC fork &amp;mdash; NOT in the reply&lt;br&gt;&amp;nbsp; path (adds no latency)&lt;br&gt;&amp;bull; Cheap GATE (state check, not LLM):&lt;br&gt;&amp;nbsp; settled+high-conf &amp;rarr; reuse posture&lt;br&gt;&amp;nbsp; tripwire: contradicting cues on a&lt;br&gt;&amp;nbsp; settled session &amp;rarr; force re-analyze&lt;br&gt;&amp;bull; Loads/updates AgeBandContext&lt;br&gt;&amp;bull; Payload: {turn_text, session_id,&lt;br&gt;&amp;nbsp; history_ref}" vertex="1">
          <mxGeometry x="110" y="320" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-config" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Policy &amp;amp; Config Setup&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; Loads the policy table:&lt;br&gt;&amp;nbsp; band × confidence → safety_posture&lt;br&gt;&amp;bull; Loads product mode:&lt;br&gt;&amp;nbsp; adult-product (protect minors)&lt;br&gt;&amp;nbsp; | kids-product (detect adults)&lt;br&gt;&amp;bull; Step-up + high-severity thresholds&lt;br&gt;&amp;bull; Trusted / signed config, not an&lt;br&gt;&amp;nbsp; arbitrary MCP response&lt;br&gt;&amp;bull; Deterministic &amp;mdash; not the LLM" vertex="1">
          <mxGeometry x="640" y="320" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-orch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Agent Orchestrator&lt;/b&gt;&lt;br&gt;(OpenAI Agents SDK &amp;mdash; Runner)&lt;br&gt;&lt;br&gt;&amp;bull; Runner.run(orchestrator,&lt;br&gt;&amp;nbsp; context=AgeBandContext)&lt;br&gt;&amp;bull; Agents (2 LLM calls total):&lt;br&gt;&amp;nbsp; signal_extractor,&lt;br&gt;&amp;nbsp; ageband_estimator&lt;br&gt;&amp;bull; Deterministic steps = plain&lt;br&gt;&amp;nbsp; tools (gate, evidence, policy)&lt;br&gt;&amp;bull; Typed output_type (Pydantic)&lt;br&gt;&amp;bull; One model serves both (split&lt;br&gt;&amp;nbsp; only if profiling justifies)" vertex="1">
          <mxGeometry x="1170" y="320" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="ue1a" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="u-hook" target="u-config">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ue1b" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="u-config" target="u-orch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="u-p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;" value="Phase 2: Signal Extraction &amp;amp; Evidence Accumulation" vertex="1">
          <mxGeometry x="70" y="640" width="1660" height="360" as="geometry" />
        </mxCell>
        <mxCell id="u-extract" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;signal_extractor&lt;/b&gt;&lt;br&gt;(LLM &amp;mdash; ONE structured pass)&lt;br&gt;&lt;br&gt;&amp;bull; Agent(instructions=extract_prompt,&lt;br&gt;&amp;nbsp; output_type=SignalSet)&lt;br&gt;&amp;bull; One pass pulls all cues:&lt;br&gt;&amp;nbsp; - vocabulary / complexity&lt;br&gt;&amp;nbsp; - topics (school, guardians,&lt;br&gt;&amp;nbsp;&amp;nbsp; curfew, homework)&lt;br&gt;&amp;nbsp; - explicit disclosure&lt;br&gt;&amp;nbsp;&amp;nbsp; ('I'm in 8th grade')&lt;br&gt;&amp;nbsp; - interaction style&lt;br&gt;&amp;bull; reading-level = deterministic tool&lt;br&gt;&amp;bull; No cue &amp;rarr; empty set (fine)" vertex="1">
          <mxGeometry x="110" y="695" width="500" height="285" as="geometry" />
        </mxCell>
        <mxCell id="u-store" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;update_evidence() tool&lt;/b&gt;&lt;br&gt;(Deterministic, session-scoped)&lt;br&gt;&lt;br&gt;&amp;bull; Appends this turn's cues to&lt;br&gt;&amp;nbsp; session evidence&lt;br&gt;&amp;bull; EPHEMERAL: session-scoped,&lt;br&gt;&amp;nbsp; not persisted as a profile&lt;br&gt;&amp;bull; Tracks corroboration &amp;mdash; do&lt;br&gt;&amp;nbsp; cues agree or conflict?&lt;br&gt;&amp;bull; Deposits state[evidence]&lt;br&gt;&amp;bull; &amp;rarr; ageband_estimator" vertex="1">
          <mxGeometry x="640" y="695" width="500" height="285" as="geometry" />
        </mxCell>
        <mxCell id="u-p2note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Why accumulate, not one-shot&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; A single message is noisy.&lt;br&gt;&amp;nbsp; Evidence across the whole&lt;br&gt;&amp;nbsp; conversation is stable.&lt;br&gt;&lt;br&gt;&amp;bull; Estimate starts at UNKNOWN&lt;br&gt;&amp;nbsp; and only moves as cues&lt;br&gt;&amp;nbsp; corroborate &amp;mdash; one ambiguous&lt;br&gt;&amp;nbsp; line won't swing it.&lt;br&gt;&lt;br&gt;&amp;bull; Nothing here is a dossier." vertex="1">
          <mxGeometry x="1170" y="695" width="500" height="285" as="geometry" />
        </mxCell>
        <mxCell id="ue2a" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="u-extract" target="u-store">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="u-p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;" value="Phase 3: Age-Band Inference (LLM)" vertex="1">
          <mxGeometry x="70" y="1040" width="1660" height="340" as="geometry" />
        </mxCell>
        <mxCell id="u-estimate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;ageband_estimator&lt;/b&gt;&lt;br&gt;(LLM proposes; confidence is grounded)&lt;br&gt;&lt;br&gt;&amp;bull; Agent(instructions=estimate_prompt,&lt;br&gt;&amp;nbsp; output_type=AgeBandEstimate)&lt;br&gt;&amp;bull; LLM proposes band + cited cues;&lt;br&gt;&amp;nbsp; also flags EVASION as a weak signal&lt;br&gt;&amp;bull; confidence = DETERMINISTIC from&lt;br&gt;&amp;nbsp; evidence (corroboration, disclosure,&lt;br&gt;&amp;nbsp; cue strength) + bounded LLM nudge&lt;br&gt;&amp;bull; Returns {band, confidence 0..1,&lt;br&gt;&amp;nbsp; signals_cited, contradictions}&lt;br&gt;&amp;bull; min-evidence gate &amp;rarr; 'unknown'" vertex="1">
          <mxGeometry x="110" y="1095" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-band" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;bands, not ages&lt;/b&gt;&lt;br&gt;(design constraint)&lt;br&gt;&lt;br&gt;&amp;bull; Output is a BAND + confidence,&lt;br&gt;&amp;nbsp; never a precise age.&lt;br&gt;&amp;bull; Text can't reliably tell 16&lt;br&gt;&amp;nbsp; from 18 &amp;mdash; so the system&lt;br&gt;&amp;nbsp; doesn't pretend to.&lt;br&gt;&amp;bull; Confidence is first-class:&lt;br&gt;&amp;nbsp; it drives how hard the policy&lt;br&gt;&amp;nbsp; is allowed to act." vertex="1">
          <mxGeometry x="640" y="1095" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-p3note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Explainable&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; signals_cited makes every&lt;br&gt;&amp;nbsp; estimate inspectable &amp;mdash; you&lt;br&gt;&amp;nbsp; can see WHY it thinks what&lt;br&gt;&amp;nbsp; it thinks.&lt;br&gt;&lt;br&gt;&amp;bull; That's what a T&amp;amp;S reviewer&lt;br&gt;&amp;nbsp; (or a regulator) needs to&lt;br&gt;&amp;nbsp; trust the signal." vertex="1">
          <mxGeometry x="1170" y="1095" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Phase 4: Graduated Policy Decision (deterministic)" vertex="1">
          <mxGeometry x="70" y="1420" width="1660" height="340" as="geometry" />
        </mxCell>
        <mxCell id="u-policy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;policy_gate() tool&lt;/b&gt;&lt;br&gt;(Deterministic &amp;mdash; the decision)&lt;br&gt;&lt;br&gt;&amp;bull; The model ESTIMATES; this&lt;br&gt;&amp;nbsp; DECIDES. Separation is the point.&lt;br&gt;&amp;bull; Maps (band, confidence) → a&lt;br&gt;&amp;nbsp; safety_posture via the table:&lt;br&gt;&amp;nbsp; - low conf &amp;rarr; tighten filters a bit&lt;br&gt;&amp;nbsp; - med conf &amp;rarr; disable mature&lt;br&gt;&amp;nbsp;&amp;nbsp; features, adjust tone&lt;br&gt;&amp;nbsp; - high conf + high impact &amp;rarr;&lt;br&gt;&amp;nbsp;&amp;nbsp; STEP-UP (don't act silently)&lt;br&gt;&amp;bull; Errs safe / biases toward ASK&lt;br&gt;&amp;nbsp; over silent restriction" vertex="1">
          <mxGeometry x="110" y="1475" width="560" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-route" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;_action_route:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;#9656; apply &amp;rarr; emit safety_posture,&lt;br&gt;&amp;nbsp; host honors it&lt;br&gt;&amp;nbsp; (low / medium confidence)&lt;br&gt;&lt;br&gt;&amp;#9656; step_up &amp;rarr;&lt;br&gt;&amp;nbsp; ask to confirm / restrict /&lt;br&gt;&amp;nbsp; hand off (high impact +&lt;br&gt;&amp;nbsp; high confidence; SYNC)&lt;br&gt;&lt;br&gt;&amp;#9656; none &amp;rarr; unknown / adult:&lt;br&gt;&amp;nbsp; no change" vertex="1">
          <mxGeometry x="700" y="1475" width="440" height="265" as="geometry" />
        </mxCell>
        <mxCell id="u-p4note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Why deterministic policy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; A tunable, auditable table &amp;mdash;&lt;br&gt;&amp;nbsp; not an LLM &amp;mdash; decides what&lt;br&gt;&amp;nbsp; happens to a user.&lt;br&gt;&lt;br&gt;&amp;bull; Product owners set the&lt;br&gt;&amp;nbsp; thresholds; the same estimate&lt;br&gt;&amp;nbsp; can drive different policies&lt;br&gt;&amp;nbsp; per product / jurisdiction." vertex="1">
          <mxGeometry x="1170" y="1475" width="500" height="265" as="geometry" />
        </mxCell>
        <mxCell id="ue4a" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="u-policy" target="u-route">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="u-p5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;" value="Phase 5: Apply, Step-up, Confirmation &amp;amp; Loop" vertex="1">
          <mxGeometry x="70" y="1800" width="1660" height="420" as="geometry" />
        </mxCell>
        <mxCell id="u-apply" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;emit safety_posture&lt;/b&gt;&lt;br&gt;(host is the enforcer)&lt;br&gt;&lt;br&gt;&amp;bull; Emits {level, flags} for this&lt;br&gt;&amp;nbsp; session:&lt;br&gt;&amp;nbsp; - content filter level&lt;br&gt;&amp;nbsp; - feature availability&lt;br&gt;&amp;nbsp; - tone / guardrail profile&lt;br&gt;&amp;bull; HOST assistant honors it &amp;mdash;&lt;br&gt;&amp;nbsp; AgeBand never touches the model&lt;br&gt;&amp;bull; proportional, reversible&lt;br&gt;&amp;bull; &amp;rarr; loop to next turn" vertex="1">
          <mxGeometry x="110" y="1855" width="440" height="300" as="geometry" />
        </mxCell>
        <mxCell id="u-stepup" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;step_up&lt;/b&gt;&lt;br&gt;(Ask, don't assume)&lt;br&gt;&lt;br&gt;&amp;bull; Only high-impact + high-conf&lt;br&gt;&amp;bull; High-severity transition = SYNC:&lt;br&gt;&amp;nbsp; blocks THAT one reply until the&lt;br&gt;&amp;nbsp; new posture applies (else async)&lt;br&gt;&amp;bull; Prompts confirm-age / restricts /&lt;br&gt;&amp;nbsp; hands off&lt;br&gt;&amp;bull; Never a silent hard-block&lt;br&gt;&amp;bull; &amp;rarr; confirmation" vertex="1">
          <mxGeometry x="590" y="1855" width="440" height="300" as="geometry" />
        </mxCell>
        <mxCell id="u-confirm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;confirmation &amp;amp; override&lt;/b&gt;&lt;br&gt;(Ground truth wins)&lt;br&gt;&lt;br&gt;&amp;bull; Explicit CONFIRMED age OVERRIDES&lt;br&gt;&amp;nbsp; the inference&lt;br&gt;&amp;bull; Only a CONFIRMED age may persist&lt;br&gt;&amp;nbsp; (against an existing account);&lt;br&gt;&amp;nbsp; INFERRED bands never persist&lt;br&gt;&amp;bull; Logged minimally (band + posture),&lt;br&gt;&amp;nbsp; not a dossier&lt;br&gt;&amp;bull; &amp;rarr; policy re-evaluates once" vertex="1">
          <mxGeometry x="1070" y="1855" width="460" height="300" as="geometry" />
        </mxCell>
        <mxCell id="ue5a" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="u-stepup" target="u-confirm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ue5b" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#9673a6;dashed=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" source="u-confirm" target="u-policy" value="override">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1300" y="1450" />
              <mxPoint x="390" y="1450" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="uc12" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="u-orch" target="u-extract" value="Runner.run()">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="uc23" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="u-store" target="u-estimate" value="evidence">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="uc34" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="u-estimate" target="u-policy" value="estimate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="uc45a" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#82b366;exitX=0.4;exitY=1;entryX=0.5;entryY=0;" edge="1" source="u-route" target="u-apply" value="posture">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="uc45b" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#b85450;exitX=0.6;exitY=1;entryX=0.5;entryY=0;" edge="1" source="u-route" target="u-stepup" value="step-up">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="uc-loop" parent="1" style="rounded=1;html=1;strokeWidth=3;strokeColor=#6c8ebf;dashed=1;exitX=0;exitY=0.5;entryX=0;entryY=0.4;" edge="1" source="u-apply" target="u-hook" value="next turn">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="60" y="2005" />
              <mxPoint x="60" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
