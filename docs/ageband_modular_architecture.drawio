        <mxCell id="n104" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="The model estimates; this module decides. A tunable, auditable table maps band × confidence to a graduated action. No LLM here." vertex="1">
