        <mxCell id="n150" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Orchestrator — Planner-Supervisor (Agents SDK)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; iterative plan &amp;rarr; act &amp;rarr; observe &amp;rarr; re-plan&lt;br&gt;&amp;nbsp; (chooses the next action; see Planner tab)&lt;br&gt;&amp;bull; registry: signal_extractor, ageband_estimator,&lt;br&gt;&amp;nbsp; stepup_composer + deterministic tools&lt;br&gt;&amp;bull; typed output_type (Pydantic) on every action&lt;br&gt;&amp;bull; deterministic guardrails + precondition checks&lt;br&gt;&amp;bull; local tracing (no external telemetry)" vertex="1">
          <mxGeometry x="90" y="130" width="560" height="220" as="geometry" />
        </mxCell>
        <mxCell id="n151" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Model Serving (AMD ROCm)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; vLLM / TGI serving open-weight models&lt;br&gt;&amp;nbsp; (Llama- / Qwen-class)&lt;br&gt;&amp;bull; OpenAI-compatible endpoint &amp;rarr; Agents SDK&lt;br&gt;&amp;nbsp; base_url override (no OpenAI cloud)&lt;br&gt;&amp;bull; model routing:&lt;br&gt;&amp;nbsp; - small model &amp;rarr; extraction subagents&lt;br&gt;&amp;nbsp; - larger model &amp;rarr; estimator reasoning&lt;br&gt;&amp;bull; continuous batching for always-on throughput" vertex="1">
          <mxGeometry x="720" y="130" width="560" height="240" as="geometry" />
        </mxCell>
        <mxCell id="n152" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;MCP Server Registry&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; MCPServerStreamableHttp / Stdio&lt;br&gt;&amp;bull; host-events (inbound turns)&lt;br&gt;&amp;bull; product-config (policy, thresholds, mode)&lt;br&gt;&amp;bull; safety-control (content filter, features, tone)&lt;br&gt;&amp;bull; age-confirmation (step-up)&lt;br&gt;&amp;bull; passed to agents via mcp_servers=[...]" vertex="1">
          <mxGeometry x="90" y="420" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="n153" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Guardrails &amp;amp; Isolation&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; input guardrail: strip / never log raw PII&lt;br&gt;&amp;bull; output guardrail: validate AgeBandEstimate,&lt;br&gt;&amp;nbsp; enforce 'bands not ages', allow 'unknown'&lt;br&gt;&amp;bull; everything inside the product boundary&lt;br&gt;&amp;bull; no external API calls, no cloud egress&lt;br&gt;&amp;bull; this is the entire deployability argument" vertex="1">
          <mxGeometry x="720" y="420" width="560" height="210" as="geometry" />
        </mxCell>
