        <mxCell id="n148" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="The OpenAI Agents SDK Runner coordinates all agents against open-weight models served locally on AMD ROCm. Nothing leaves the boundary." vertex="1">
          <mxGeometry x="60" y="52" width="1480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n149" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1290" y="30" width="360" height="130" as="geometry" />
