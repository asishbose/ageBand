<mxfile host="Electron" agent="ageband-modular" pages="12">
  <diagram name="1 · Integration Architecture" id="t1">
    <mxGraphModel dx="1709" dy="1045" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n1" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="AgeBand — Integration Architecture (modules, tools &amp;amp; MCP boundaries)" vertex="1">
          <mxGeometry height="30" width="1300" x="60" y="20" as="geometry" />
        </mxCell>
        <mxCell id="n2" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Everything runs inside the host product boundary; the only external surfaces are MCP calls to the host's own safety controls and config" vertex="1">
          <mxGeometry height="20" width="1300" x="60" y="52" as="geometry" />
        </mxCell>
        <mxCell id="n3" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry height="130" width="360" x="1400" y="40" as="geometry" />
        </mxCell>
        <mxCell id="n4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;strokeColor=#6c8ebf;fillColor=#f7fbff;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;fontColor=#1A4E80;" value="Host AI chat product — on-prem (operator boundary)" vertex="1">
          <mxGeometry height="960" width="1680" x="60" y="100" as="geometry" />
        </mxCell>
        <mxCell id="n5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;M1 · Gateway &amp;amp; Session&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; receives TurnEvent (async fork,&lt;br&gt;&amp;nbsp; NOT in the reply path)&lt;br&gt;&amp;bull; filters to USER turns only&lt;br&gt;&amp;bull; attaches to session &amp;rarr; AgeBandContext&lt;br&gt;&amp;bull; entry: host hook / middleware / stream&lt;br&gt;&amp;nbsp; (see 'Input &amp;amp; Entry' tab)" vertex="1">
          <mxGeometry height="145" width="240" x="100" y="165" as="geometry" />
        </mxCell>
        <mxCell id="n6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;M1.5 · Cheap Gate&lt;/b&gt;&lt;br&gt;(state check, NOT an LLM call)&lt;br&gt;&lt;br&gt;&amp;bull; reads session state (band, conf, turns)&lt;br&gt;&amp;bull; always-on heuristic TRIPWIRE:&lt;br&gt;&amp;nbsp; contradicting cues on a settled&lt;br&gt;&amp;nbsp; session &amp;rarr; force re-analysis&lt;br&gt;&amp;nbsp; (handles mid-session device handoff)&lt;br&gt;&amp;bull; else settled &amp;rarr; reuse posture" vertex="1">
          <mxGeometry height="145" width="240" x="100" y="330" as="geometry" />
        </mxCell>
        <mxCell id="n7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;M2 · Signal Extraction&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; ONE structured extraction pass&lt;br&gt;&amp;nbsp; (lexical · topic · disclosure · style)&lt;br&gt;&amp;bull; reading-level = deterministic tool&lt;br&gt;&amp;bull; runs only when the gate says so&lt;br&gt;&amp;bull; out: SignalSet" vertex="1">
          <mxGeometry height="150" width="240" x="100" y="490" as="geometry" />
        </mxCell>
        <mxCell id="n8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;M3 · Evidence Fabric&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; session-scoped, ephemeral&lt;br&gt;&amp;bull; corroboration + decay&lt;br&gt;&amp;bull; tools: update / read / decay&lt;br&gt;&amp;bull; NO profile, NO PII" vertex="1">
          <mxGeometry height="130" width="240" x="100" y="670" as="geometry" />
        </mxCell>
        <mxCell id="n9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;M4 · Age-Band Inference&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; estimator: LLM or offline rule_estimator&lt;br&gt;&amp;bull; &lt;b&gt;lexical-gate (_STRONG_TYPES):&lt;/b&gt;&lt;br&gt;&amp;nbsp; vocab/style/reading_level alone cannot&lt;br&gt;&amp;nbsp; establish a band — topic/disclosure required&lt;br&gt;&amp;bull; confidence = DETERMINISTIC from evidence&lt;br&gt;&amp;bull; out: AgeBandEstimate {band, cues}" vertex="1">
          <mxGeometry height="150" width="260" x="430" y="330" as="geometry" />
        </mxCell>
        <mxCell id="n10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;M5 · Policy &amp;amp; Decision&lt;/b&gt;&lt;br&gt;(deterministic)&lt;br&gt;&lt;br&gt;&amp;bull; policy table: band×conf→action&lt;br&gt;&amp;bull; product mode + jurisdiction&lt;br&gt;&amp;bull; step-up threshold&lt;br&gt;&amp;bull; out: Decision" vertex="1">
          <mxGeometry height="150" width="260" x="780" y="330" as="geometry" />
        </mxCell>
        <mxCell id="n11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;M6 · Enforcement&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; emits safety_posture {level, flags}&lt;br&gt;&amp;bull; HOST honors it (AgeBand does not&lt;br&gt;&amp;nbsp; touch the model / reply path)&lt;br&gt;&amp;bull; proportional · reversible&lt;br&gt;&amp;bull; MCP out: safety-control" vertex="1">
          <mxGeometry height="140" width="250" x="1120" y="300" as="geometry" />
        </mxCell>
        <mxCell id="n12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;M7 · Step-up &amp;amp; Verification&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; high-severity transition = SYNC&lt;br&gt;&amp;nbsp; (blocks that one reply); else async&lt;br&gt;&amp;bull; step-up prompt / restrict / handoff&lt;br&gt;&amp;bull; explicit CONFIRMED age &amp;rarr; may persist&lt;br&gt;&amp;nbsp; (inferred bands never do)&lt;br&gt;&amp;bull; MCP out: age-confirmation" vertex="1">
          <mxGeometry height="150" width="250" x="1120" y="470" as="geometry" />
        </mxCell>
        <mxCell id="n13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;M8 · Audit, Telemetry &amp;amp; Fairness&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; minimal ephemeral logs (band+action)&lt;br&gt;&amp;bull; false-positive / bias monitoring&lt;br&gt;&amp;bull; decision + rule-fired trace&lt;br&gt;&amp;bull; NO dossier" vertex="1">
          <mxGeometry height="110" width="610" x="430" y="540" as="geometry" />
        </mxCell>
        <mxCell id="n14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;M9 · Model Serving (AMD)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; vLLM / TGI on ROCm&lt;br&gt;&amp;bull; OpenAI-compatible endpoint&lt;br&gt;&amp;bull; small model = extraction,&lt;br&gt;&amp;nbsp; larger = estimator · batched" vertex="1">
          <mxGeometry height="150" width="300" x="430" y="710" as="geometry" />
        </mxCell>
        <mxCell id="n15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;M10 · Planner-Supervisor (Agents SDK)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; iterative plan &amp;rarr; act &amp;rarr; observe &amp;rarr; re-plan&lt;br&gt;&amp;bull; chooses the NEXT action (tool or delegate),&lt;br&gt;&amp;nbsp; not a hardcoded pipeline&lt;br&gt;&amp;bull; deterministic guardrails: cannot emit posture,&lt;br&gt;&amp;nbsp; skip/reorder guards, or persist inferred&lt;br&gt;&amp;bull; bounded iterations &amp;rarr; safe default&lt;br&gt;&amp;bull; (see 'Planner-Supervisor' tab)" vertex="1">
          <mxGeometry height="160" width="320" x="780" y="700" as="geometry" />
        </mxCell>
        <mxCell id="n16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Product Config&lt;/b&gt;&lt;br&gt;(MCP)&lt;br&gt;policy table,&lt;br&gt;thresholds, mode" vertex="1">
          <mxGeometry height="90" width="200" x="1150" y="710" as="geometry" />
        </mxCell>
        <mxCell id="n17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Host assistant&lt;/b&gt;&lt;br&gt;reply path&lt;br&gt;(content filter,&lt;br&gt;features, tone)" vertex="1">
          <mxGeometry height="120" width="190" x="1470" y="340" as="geometry" />
