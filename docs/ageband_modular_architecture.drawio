        <mxCell id="n204" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#1A1A2E;" value="Three integration modes — pick per how much of the host you control" vertex="1">
          <mxGeometry x="520" y="120" width="700" height="24" as="geometry" />
        </mxCell>
        <mxCell id="n205" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Mode 1 · Event hook / callback&lt;/b&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;(recommended)&lt;/i&gt;&lt;br&gt;&lt;br&gt;&amp;bull; Host emits an event on every user turn (most&lt;br&gt;&amp;nbsp; products already have message-received middleware)&lt;br&gt;&amp;bull; AgeBand subscribes; the event IS the input&lt;br&gt;&amp;bull; Non-invasive: host just notifies, doesn't route&lt;br&gt;&amp;bull; &lt;b&gt;Needs:&lt;/b&gt; ability to add/subscribe to a hook&lt;br&gt;&amp;bull; &lt;b&gt;Best when:&lt;/b&gt; you control (or can extend) the host" vertex="1">
          <mxGeometry x="520" y="160" width="600" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n206" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Mode 2 · Middleware / interceptor&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; AgeBand sits pass-through in the message pipeline&lt;br&gt;&amp;bull; Can GATE the reply (hold it) &amp;mdash; but that adds&lt;br&gt;&amp;nbsp; latency, so pass through instantly by default and&lt;br&gt;&amp;nbsp; only hold for a rare high-impact step-up&lt;br&gt;&amp;bull; &lt;b&gt;Needs:&lt;/b&gt; a seat in the request path&lt;br&gt;&amp;bull; &lt;b&gt;Best when:&lt;/b&gt; you need the option to block inline" vertex="1">
          <mxGeometry x="520" y="340" width="600" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n207" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Mode 3 · Sidecar reading a stream&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; Host writes turns to a queue / log; AgeBand consumes&lt;br&gt;&amp;bull; Fully decoupled; scales well; most plumbing&lt;br&gt;&amp;bull; &lt;b&gt;Needs:&lt;/b&gt; a turn stream / event bus&lt;br&gt;&amp;bull; &lt;b&gt;Best when:&lt;/b&gt; third-party host you can only sit&lt;br&gt;&amp;nbsp; beside, or very high volume" vertex="1">
          <mxGeometry x="520" y="520" width="600" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n208" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;TurnEvent&lt;/b&gt; (the input payload)&lt;br&gt;&lt;br&gt;{&lt;br&gt;&amp;nbsp; session_id&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;# a SESSION, not a user identity&lt;br&gt;&amp;nbsp; turn_text&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;# the user's message (the signal)&lt;br&gt;&amp;nbsp; role&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;# only role=user is analyzed&lt;br&gt;&amp;nbsp; timestamp&lt;br&gt;&amp;nbsp; history_ref&amp;nbsp;&amp;nbsp;# pointer to in-session turns, not the transcript&lt;br&gt;&amp;nbsp; product_context # surface / jurisdiction &amp;rarr; drives policy&lt;br&gt;}" vertex="1">
          <mxGeometry x="1180" y="160" width="540" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n209" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;M1 · Gateway &amp;amp; Session&lt;/b&gt; (input handling)&lt;br&gt;&lt;br&gt;&amp;bull; receives TurnEvent from the chosen mode&lt;br&gt;&amp;bull; &lt;b&gt;filters to USER turns&lt;/b&gt; (assistant turns ignored &amp;mdash;&lt;br&gt;&amp;nbsp; analyzing your own output tells you nothing)&lt;br&gt;&amp;bull; attaches turn to the right session:&lt;br&gt;&amp;nbsp; - new &amp;rarr; create AgeBandContext&lt;br&gt;&amp;nbsp; - existing &amp;rarr; resume accumulated evidence (M3)&lt;br&gt;&amp;bull; hands off to the Runner" vertex="1">
          <mxGeometry x="1180" y="400" width="540" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n210" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Runner.run(context=AgeBandContext)&lt;/b&gt;&lt;br&gt;extractor input = {turn_text, session_id, history_ref}" vertex="1">
          <mxGeometry x="1180" y="640" width="540" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n211" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Key point:&lt;/b&gt; input is ONE turn at a time, but the value is CUMULATIVE across turns. M1's real job is routing each turn to the correct session's accumulated evidence &amp;mdash; which is why M3 (Evidence Fabric) is keyed by session_id. Single-turn input + session-scoped state are two halves of one design." vertex="1">
          <mxGeometry x="520" y="700" width="600" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e212" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#666;dashed=1;endArrow=open;" edge="1" source="n205" target="n208" value="emit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e213" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#666;dashed=1;endArrow=open;" edge="1" source="n206" target="n208">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e214" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#666;dashed=1;endArrow=open;" edge="1" source="n207" target="n208">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e215" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n208" target="n209">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e216" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n209" target="n210" value="handoff">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e217" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#9673a6;dashed=1;endArrow=open;" edge="1" source="n199" target="n209" value="TurnEvent">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="735" />
              <mxPoint x="1180" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2 · M2 Signal Extraction" id="t2">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1680" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n37" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="Module M2 — Signal Extraction" vertex="1">
          <mxGeometry x="60" y="20" width="1480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n38" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Preferred: ONE structured extraction pass (below, as an aggregated agent). The four specialist subagents are an OPTIONAL scale-out, used only if a single pass proves too coarse. Cues-only, no PII." vertex="1">
          <mxGeometry x="60" y="52" width="1480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n39" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1290" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n40" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Input&lt;/b&gt;&lt;br&gt;{turn_text, session_id,&lt;br&gt;history_ref}" vertex="1">
          <mxGeometry x="80" y="130" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n41" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;signal_extractor&lt;/b&gt;&lt;br&gt;(coordinator Agent)&lt;br&gt;&lt;br&gt;&amp;bull; Agent(output_type=SignalSet)&lt;br&gt;&amp;bull; fans out to subagents&lt;br&gt;&amp;nbsp; (parallel where independent)&lt;br&gt;&amp;bull; aggregates + weights cues&lt;br&gt;&amp;bull; drops PII, keeps abstract cues" vertex="1">
          <mxGeometry x="350" y="110" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n42" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;LexicalAnalyzer&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; vocabulary richness,&lt;br&gt;&amp;nbsp; sentence complexity,&lt;br&gt;&amp;nbsp; reading level, spelling patterns&lt;br&gt;&amp;bull; tool: reading_level()&lt;br&gt;&amp;nbsp; (textstat, deterministic)&lt;br&gt;&amp;bull; out: LexicalSignals" vertex="1">
          <mxGeometry x="750" y="90" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n43" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;TopicClassifier&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; age-indicative topics: grade,&lt;br&gt;&amp;nbsp; homework, guardians, curfew,&lt;br&gt;&amp;nbsp; workplace, mortgage, kids...&lt;br&gt;&amp;bull; tool: lexicon_lookup()&lt;br&gt;&amp;bull; out: TopicSignals" vertex="1">
          <mxGeometry x="750" y="260" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n44" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;SelfDisclosureExtractor&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; explicit statements:&lt;br&gt;&amp;nbsp; 'I'm 14', 'in 8th grade',&lt;br&gt;&amp;nbsp; 'my mom won't let me'&lt;br&gt;&amp;bull; HIGHEST weight when present&lt;br&gt;&amp;bull; out: DisclosureSignals" vertex="1">
          <mxGeometry x="750" y="430" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n45" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;StyleProfiler&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; interaction style, formality,&lt;br&gt;&amp;nbsp; emoji / slang patterns,&lt;br&gt;&amp;nbsp; turn length&lt;br&gt;&amp;bull; weak signal (context only)&lt;br&gt;&amp;bull; out: StyleSignals" vertex="1">
          <mxGeometry x="750" y="600" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n46" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;aggregate()&lt;/b&gt;&lt;br&gt;(deterministic merge)&lt;br&gt;&lt;br&gt;&amp;bull; combine 4 signal groups&lt;br&gt;&amp;bull; attach per-cue weight +&lt;br&gt;&amp;nbsp; source subagent&lt;br&gt;&amp;bull; emit SignalSet" vertex="1">
          <mxGeometry x="1150" y="300" width="250" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n47" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Output → M3&lt;/b&gt;&lt;br&gt;SignalSet {&lt;br&gt;&amp;nbsp; lexical[], topic[],&lt;br&gt;&amp;nbsp; disclosure[], style[],&lt;br&gt;&amp;nbsp; per-cue: {type, value,&lt;br&gt;&amp;nbsp;&amp;nbsp; weight, turn, source} }" vertex="1">
          <mxGeometry x="1150" y="500" width="250" height="170" as="geometry" />
        </mxCell>
        <mxCell id="n48" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Model Serving (AMD)&lt;/b&gt;&lt;br&gt;small open-weight model&lt;br&gt;serves the LLM subagents&lt;br&gt;(OpenAI-compatible / vLLM ROCm)" vertex="1">
          <mxGeometry x="350" y="500" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n49" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Guardrail&lt;/b&gt;: output-type validation on SignalSet · no raw PII persisted · empty set is valid (no cues this turn)" vertex="1">
          <mxGeometry x="350" y="640" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="e50" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n40" target="n41">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e51" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n41" target="n42">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e52" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#333;endArrow=block;" edge="1" source="n42" target="n46">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e53" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n41" target="n43">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e54" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#333;endArrow=block;" edge="1" source="n43" target="n46">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e55" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n41" target="n44">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e56" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#333;endArrow=block;" edge="1" source="n44" target="n46">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e57" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n41" target="n45">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e58" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#333;endArrow=block;" edge="1" source="n45" target="n46">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e59" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n46" target="n47">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e60" parent="1" style="rounded=1;html=1;strokeWidth=1;strokeColor=#b85450;dashed=1;endArrow=open;" edge="1" source="n48" target="n41" value="serve">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n61" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="reading_level()&lt;br&gt;tool" vertex="1">
          <mxGeometry x="1120" y="90" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n62" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="lexicon_lookup()&lt;br&gt;tool" vertex="1">
          <mxGeometry x="1120" y="260" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e63" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#d79b00;dashed=1;endArrow=open;" edge="1" source="n42" target="n61">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e64" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#d79b00;dashed=1;endArrow=open;" edge="1" source="n43" target="n62">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3 · M4 Age-Band Inference" id="t3">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1680" pageHeight="1060" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n65" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="Module M4 — Age-Band Inference" vertex="1">
          <mxGeometry x="60" y="20" width="1480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n66" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Estimator (LLM or offline rule_estimator) proposes a band + cited cues; confidence is always deterministic. Lexical cues (vocab/style/reading_level) cannot establish a band alone — topic/disclosure cue required (_STRONG_TYPES fairness guard, PR #2). Also flags EVASION — inference decides WHEN to step up, it is not the security boundary." vertex="1">
          <mxGeometry x="60" y="52" width="1480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n67" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1290" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n68" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Input&lt;/b&gt;&lt;br&gt;accumulated evidence&lt;br&gt;(from M3)" vertex="1">
          <mxGeometry x="80" y="140" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n69" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;ageband_estimator&lt;/b&gt;&lt;br&gt;(coordinator Agent)&lt;br&gt;&lt;br&gt;&amp;bull; Agent(output_type=&lt;br&gt;&amp;nbsp; AgeBandEstimate)&lt;br&gt;&amp;bull; min-evidence gate: below&lt;br&gt;&amp;nbsp; threshold &amp;rarr; band=unknown&lt;br&gt;&amp;bull; orchestrates 3 subagents&lt;br&gt;&amp;bull; assembles final estimate" vertex="1">
          <mxGeometry x="340" y="120" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="n70" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;EvidenceReasoner&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; reasons over all cues &amp;rarr;&lt;br&gt;&amp;nbsp; candidate band + rationale&lt;br&gt;&amp;bull; weighs disclosure &amp;gt; topic &amp;gt; lexical&lt;br&gt;&amp;bull; &lt;i&gt;offline (rule_estimator):&lt;/i&gt; lexical&lt;br&gt;&amp;nbsp; cues EXCLUDED — only topic/disclosure&lt;br&gt;&amp;nbsp; can establish a band (_STRONG_TYPES)&lt;br&gt;&amp;bull; out: {candidate_band, rationale}" vertex="1">
          <mxGeometry x="740" y="110" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n71" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;ConfidenceCalibrator&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; raw reasoning &amp;rarr; calibrated&lt;br&gt;&amp;nbsp; confidence 0..1&lt;br&gt;&amp;bull; factors: evidence volume,&lt;br&gt;&amp;nbsp; corroboration, recency&lt;br&gt;&amp;bull; tool: calibration_table()&lt;br&gt;&amp;bull; out: {confidence}" vertex="1">
          <mxGeometry x="740" y="280" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n72" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e9f5e4;strokeColor=#82b366;" value="&lt;b&gt;ContradictionChecker&lt;/b&gt; (subagent)&lt;br&gt;&lt;br&gt;&amp;bull; flags conflicting cues&lt;br&gt;&amp;nbsp; (adult topics + child vocab)&lt;br&gt;&amp;bull; caps confidence when signals&lt;br&gt;&amp;nbsp; disagree &amp;rarr; prevents overconfidence&lt;br&gt;&amp;bull; out: {contradictions[]}" vertex="1">
          <mxGeometry x="740" y="450" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n73" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;assemble()&lt;/b&gt;&lt;br&gt;(deterministic)&lt;br&gt;&lt;br&gt;&amp;bull; combine band + calibrated&lt;br&gt;&amp;nbsp; confidence + contradictions&lt;br&gt;&amp;bull; validate against schema" vertex="1">
