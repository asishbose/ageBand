  <diagram name="11 · Synthetic Eval Harness (dual-LLM)" id="t11">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1680" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="se_t" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="AgeBand — Synthetic Eval Harness (proposal — two independent LLMs)" vertex="1">
          <mxGeometry x="60" y="20" width="1400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="se_sub" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Model A writes synthetic multi-turn chats for a target (band, difficulty); Model B is what the REAL pipeline uses to classify them. Different models avoid a model just recognising its own writing style, and give a quantifiable fairness/accuracy eval — not part of the production reply path." vertex="1">
          <mxGeometry x="60" y="52" width="1500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="se_legend" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;──&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1400" y="30" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="se_params" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Sample spec&lt;/b&gt;&lt;br&gt;&lt;br&gt;band: child | teen | adult&lt;br&gt;difficulty: clear | ambiguous | evasive&lt;br&gt;turn_count: 3–8&lt;br&gt;(evasive = persona claims an age&lt;br&gt;that contradicts its own cues)" vertex="1">
          <mxGeometry x="80" y="140" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="se_gen_agent" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;chat_generator&lt;/b&gt; (new agent)&lt;br&gt;&lt;br&gt;&amp;bull; writes a short multi-turn synthetic&lt;br&gt;&amp;nbsp; transcript for the given (band, difficulty)&lt;br&gt;&amp;bull; benign topics only — school, games,&lt;br&gt;&amp;nbsp; hobbies, homework; no PII, no real names&lt;br&gt;&amp;bull; out: {band, difficulty, turns[], notes}" vertex="1">
          <mxGeometry x="400" y="120" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="se_gen_model" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Model Serving A (AMD ROCm)&lt;/b&gt;&lt;br&gt;GENERATOR_API_BASE / GENERATOR_MODEL&lt;br&gt;independent vLLM endpoint — writer only,&lt;br&gt;never touches the real pipeline" vertex="1">
          <mxGeometry x="400" y="330" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se_fixtures" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;tests/fixtures/synthetic/&lt;/b&gt;&lt;br&gt;&lt;br&gt;{band}_{difficulty}_{n}.json&lt;br&gt;ground truth baked in&lt;br&gt;(band + difficulty + generation_model)" vertex="1">
          <mxGeometry x="780" y="140" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="se_pipeline" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;REAL pipeline replay&lt;/b&gt; (unchanged code)&lt;br&gt;&lt;br&gt;gate → signal_extraction → evidence_fabric&lt;br&gt;→ ageband_inference → policy_decision&lt;br&gt;&amp;bull; AGEBAND_INFERENCE_MODE=llm forced&lt;br&gt;&amp;bull; turns replayed one at a time, in order" vertex="1">
          <mxGeometry x="1140" y="120" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="se_eval_model" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Model Serving B (AMD ROCm)&lt;/b&gt;&lt;br&gt;EVAL_API_BASE / EVAL_MODEL — a DIFFERENT&lt;br&gt;model/process than Model A; this is the&lt;br&gt;model the shipped pipeline actually uses" vertex="1">
          <mxGeometry x="1140" y="330" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se_results" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Eval report&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; confusion matrix (band × band)&lt;br&gt;&amp;bull; precision / recall / F1 per band&lt;br&gt;&amp;bull; false-positive rate by difficulty tier&lt;br&gt;&amp;bull; feeds src/audit_fairness/ trace format" vertex="1">
          <mxGeometry x="780" y="480" width="680" height="140" as="geometry" />
        </mxCell>
        <mxCell id="se_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Not wired into pytest/CI&lt;/b&gt; — calls real LLM endpoints, so it lives under scripts/ as a manual eval tool (make eval-synthetic), not tests/. Doubles as an AMD/vLLM utilization demo: two distinct models served concurrently." vertex="1">
          <mxGeometry x="80" y="480" width="680" height="90" as="geometry" />
        </mxCell>
        <mxCell id="se_e1" edge="1" parent="1" source="se_params" target="se_gen_agent" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se_e2" edge="1" parent="1" source="se_gen_model" target="se_gen_agent" style="rounded=1;html=1;strokeWidth=1;strokeColor=#b85450;dashed=1;endArrow=open;" value="serve">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se_e3" edge="1" parent="1" source="se_gen_agent" target="se_fixtures" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" value="write fixture">
