        </mxCell>
        <mxCell id="n105" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1230" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n106" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Input&lt;/b&gt;&lt;br&gt;AgeBandEstimate&lt;br&gt;(from M4)" vertex="1">
          <mxGeometry x="80" y="150" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n107" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;policy_gate()&lt;/b&gt;&lt;br&gt;(deterministic engine)&lt;br&gt;&lt;br&gt;&amp;bull; NO LLM &amp;mdash; pure rules&lt;br&gt;&amp;bull; bucket confidence: low /&lt;br&gt;&amp;nbsp; med / high&lt;br&gt;&amp;bull; look up (band, bucket) in&lt;br&gt;&amp;nbsp; the policy table&lt;br&gt;&amp;bull; apply product mode +&lt;br&gt;&amp;nbsp; jurisdiction overrides" vertex="1">
          <mxGeometry x="340" y="120" width="300" height="180" as="geometry" />
        </mxCell>
        <mxCell id="n108" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;Policy Table&lt;/b&gt; (config)&lt;br&gt;&lt;br&gt;(band × conf) &amp;rarr; action set&lt;br&gt;&amp;bull; teen · low &amp;rarr; tighten filters a bit&lt;br&gt;&amp;bull; teen · med &amp;rarr; disable mature&lt;br&gt;&amp;nbsp; features, adjust tone&lt;br&gt;&amp;bull; child · high &amp;rarr; STEP-UP&lt;br&gt;&amp;bull; adult / unknown &amp;rarr; no change" vertex="1">
          <mxGeometry x="740" y="110" width="340" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n109" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;Product Config&lt;/b&gt; (MCP)&lt;br&gt;&lt;br&gt;&amp;bull; product_mode:&lt;br&gt;&amp;nbsp; adult-protect-minors |&lt;br&gt;&amp;nbsp; kids-detect-adults&lt;br&gt;&amp;bull; jurisdiction thresholds&lt;br&gt;&amp;bull; step-up threshold&lt;br&gt;&amp;bull; feature map" vertex="1">
          <mxGeometry x="740" y="300" width="340" height="170" as="geometry" />
        </mxCell>
        <mxCell id="n110" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;_action_route&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;#9656; apply &amp;rarr; M6 (low/med)&lt;br&gt;&amp;#9656; step_up &amp;rarr; M7&lt;br&gt;&amp;nbsp; (high impact + high conf)&lt;br&gt;&amp;#9656; none &amp;rarr; unknown / adult" vertex="1">
          <mxGeometry x="1150" y="120" width="300" height="160" as="geometry" />
