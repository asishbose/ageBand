  <diagram name="1b · Input &amp;amp; Entry" id="t1b">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="1160" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n193" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="AgeBand — Input &amp;amp; Entry (how a turn reaches the multi-agent system)" vertex="1">
          <mxGeometry x="60" y="20" width="1400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n194" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="AgeBand runs ALONGSIDE the reply, not inside it. The user's turn forks: the assistant answers immediately; AgeBand updates the session's safety posture in parallel." vertex="1">
          <mxGeometry x="60" y="52" width="1500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n195" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1360" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n196" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;User&lt;/b&gt;&lt;br&gt;sends a chat message" vertex="1">
          <mxGeometry x="90" y="150" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n197" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Host product — message received&lt;/b&gt;&lt;br&gt;(the turn forks two ways)" vertex="1">
          <mxGeometry x="90" y="300" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n198" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Assistant reply path&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; answers the user immediately&lt;br&gt;&amp;bull; reads the CURRENT session&lt;br&gt;&amp;nbsp; safety posture (set by AgeBand)&lt;br&gt;&amp;bull; NOT blocked on AgeBand" vertex="1">
          <mxGeometry x="90" y="460" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n199" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;AgeBand (async, parallel)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; receives the same turn as a&lt;br&gt;&amp;nbsp; TurnEvent&lt;br&gt;&amp;bull; updates safety posture for&lt;br&gt;&amp;nbsp; this + next turn&lt;br&gt;&amp;bull; adds no latency to the reply" vertex="1">
          <mxGeometry x="90" y="660" width="300" height="150" as="geometry" />
        </mxCell>
