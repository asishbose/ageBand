  <diagram name="10 · Planner-Supervisor" id="t10">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n241" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="AgeBand — Runtime Planner-Supervisor (agentic orchestration, deterministically guardrailed)" vertex="1">
          <mxGeometry x="60" y="20" width="1400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n242" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Orchestration is NOT a hardcoded pipeline: a planner agent iteratively decides the next action. But it can only REQUEST safety actions — deterministic guards decide the outcome and fail closed." vertex="1">
          <mxGeometry x="60" y="52" width="1500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n243" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1360" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n244" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Session state&lt;/b&gt;&lt;br&gt;(band, confidence, settled?,&lt;br&gt;turn count, evidence summary)" vertex="1">
          <mxGeometry x="100" y="150" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n245" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;1 · PLAN&lt;/b&gt; (planner_supervisor, LLM)&lt;br&gt;&lt;br&gt;&amp;bull; given state + goal ('produce/refresh a&lt;br&gt;&amp;nbsp; safe safety_posture for this turn')&lt;br&gt;&amp;bull; choose the NEXT single action&lt;br&gt;&amp;bull; emits a TYPED action request (Pydantic)" vertex="1">
          <mxGeometry x="100" y="290" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="n246" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;2 · ACT&lt;/b&gt; (orchestration executes)&lt;br&gt;&lt;br&gt;&amp;bull; run exactly one action:&lt;br&gt;&amp;nbsp; a deterministic tool OR a delegate subagent&lt;br&gt;&amp;bull; ONLY after precondition check (below)" vertex="1">
          <mxGeometry x="100" y="470" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n247" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;3 · OBSERVE&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; read the typed result&lt;br&gt;&amp;bull; update session state" vertex="1">
          <mxGeometry x="100" y="640" width="400" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n248" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;4 · RE-PLAN or FINISH&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; posture emitted or step-up raised &amp;rarr; DONE&lt;br&gt;&amp;bull; else loop (bounded: &amp;le; N iterations)&lt;br&gt;&amp;bull; cap hit &amp;rarr; safe default posture (fail closed)" vertex="1">
          <mxGeometry x="100" y="790" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e249" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n244" target="n245">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e250" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n245" target="n246" value="typed action">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e251" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n246" target="n247" value="result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e252" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n247" target="n248">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e253" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#6c8ebf;dashed=1;endArrow=block;" edge="1" source="n248" target="n245" value="re-plan">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="855" />
              <mxPoint x="560" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="n254" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#1A1A2E;" value="Actions the planner may request" vertex="1">
          <mxGeometry x="640" y="150" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="n255" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Deterministic tools&lt;/b&gt; (Python, no LLM)&lt;br&gt;&lt;br&gt;gate_check · read_evidence · compute_confidence ·&lt;br&gt;policy_decide · emit_posture · persist_confirmed" vertex="1">
          <mxGeometry x="640" y="185" width="480" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n256" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Delegate subagents&lt;/b&gt; (YAML, LLM)&lt;br&gt;&lt;br&gt;signal_extractor &amp;rarr; SignalSet&lt;br&gt;ageband_estimator &amp;rarr; band + cues + evasion flag&lt;br&gt;stepup_composer &amp;rarr; step-up message" vertex="1">
          <mxGeometry x="640" y="310" width="480" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n257" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#b85450;" value="&lt;b&gt;Deterministic guardrails — the planner chooses the ROUTE, not the safety OUTCOME&lt;/b&gt;" vertex="1">
          <mxGeometry x="640" y="470" width="900" height="24" as="geometry" />
        </mxCell>
        <mxCell id="n258" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Cannot emit safety_posture itself&lt;/b&gt; — only the deterministic policy_decide / emit_posture tools produce one. Planner may only REQUEST a decision." vertex="1">
          <mxGeometry x="640" y="505" width="900" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n259" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Cannot skip / reorder safety guards&lt;/b&gt; — a posture may only follow a valid estimate + deterministic compute_confidence + policy_decide. Orchestration validates preconditions and REJECTS out-of-order actions (fail closed)." vertex="1">
          <mxGeometry x="640" y="575" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n260" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Confidence is always deterministic&lt;/b&gt; — never taken from the LLM. &lt;b&gt;Persistence&lt;/b&gt;: only persist_confirmed (explicit user-confirmed age) persists; inferred bands never do — planner cannot persist an inferred band." vertex="1">
          <mxGeometry x="640" y="655" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n261" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Sync/async is enforced deterministically&lt;/b&gt; — a high-severity transition forces the synchronous step-up path; the planner does not get to choose it. &lt;b&gt;Bounded loop&lt;/b&gt; caps iterations &amp;rarr; safe default posture." vertex="1">
          <mxGeometry x="640" y="735" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n262" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;precondition check&lt;/b&gt;&lt;br&gt;(orchestration)&lt;br&gt;valid + in-order?&lt;br&gt;&amp;rarr; run &amp;nbsp;|&amp;nbsp; else REJECT" vertex="1">
          <mxGeometry x="540" y="300" width="90" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e263" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n246" target="n262" value="request">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e264" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#82b366;endArrow=block;" edge="1" source="n262" target="n255" value="ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e265" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#82b366;endArrow=block;" edge="1" source="n262" target="n256" value="ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e266" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;endArrow=block;" edge="1" source="n262" target="n245" value="reject → re-plan">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="585" y="260" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="n267" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Why this shape:&lt;/b&gt; the open-ended judgment ('is there enough evidence yet? re-extract? settled? escalate?') is where planning genuinely helps — so it's an LLM. The safety-critical outcome (confidence, decision, posture, persistence, sync) stays deterministic and fails closed. Agentic where it helps; deterministic where it must be." vertex="1">
          <mxGeometry x="640" y="825" width="900" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="9 · Lean 'As-Built' (ship first)" id="t9">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1640" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n218" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="AgeBand — Lean 'As-Built' view (what actually ships first)" vertex="1">
          <mxGeometry x="60" y="20" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n219" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Stripped to essentials: TWO LLM calls (extract, estimate) wrapped in deterministic plumbing. The module map shows the thinking; this is the buildable core." vertex="1">
          <mxGeometry x="60" y="52" width="1400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n220" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1240" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n221" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;TurnEvent&lt;/b&gt;&lt;br&gt;(async fork,&lt;br&gt;user turns only)" vertex="1">
          <mxGeometry x="80" y="150" width="170" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n222" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;gate()&lt;/b&gt;&lt;br&gt;(state check +&lt;br&gt;tripwire, NOT LLM)&lt;br&gt;&lt;br&gt;settled+high-conf?&lt;br&gt;reuse posture.&lt;br&gt;tripwire/thin &amp;rarr; analyze" vertex="1">
          <mxGeometry x="300" y="140" width="190" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n223" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;extract&lt;/b&gt; (LLM or offline keyword scan)&lt;br&gt;&lt;br&gt;one structured pass &amp;rarr; SignalSet&lt;br&gt;weights re-stamped from lexicon&lt;br&gt;(reading-level = deterministic tool)" vertex="1">
          <mxGeometry x="540" y="140" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n224" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;evidence&lt;/b&gt;&lt;br&gt;(deterministic,&lt;br&gt;ephemeral, session)&lt;br&gt;&lt;br&gt;accumulate cues&lt;br&gt;+ corroboration" vertex="1">
          <mxGeometry x="810" y="140" width="200" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n225" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;estimate&lt;/b&gt; (LLM or offline rule_estimator)&lt;br&gt;&lt;br&gt;band + cited cues; confidence&lt;br&gt;always deterministic.&lt;br&gt;Offline: lexical cues excluded&lt;br&gt;(_STRONG_TYPES fairness guard)" vertex="1">
          <mxGeometry x="1060" y="140" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n226" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;policy()&lt;/b&gt;&lt;br&gt;(deterministic table)&lt;br&gt;&lt;br&gt;band &amp;times; conf &amp;rarr;&lt;br&gt;safety_posture&lt;br&gt;+ step-up threshold" vertex="1">
          <mxGeometry x="1330" y="140" width="230" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n227" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;safety_posture&lt;/b&gt; {level, flags}&lt;br&gt;&amp;rarr; host assistant honors it (host is the enforcer)" vertex="1">
          <mxGeometry x="540" y="360" width="470" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n228" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;step-up&lt;/b&gt; (high-impact + high-conf; SYNC — blocks that one reply)&lt;br&gt;ask to confirm age &amp;rarr; CONFIRMED age overrides &amp;amp; may persist; inferred never does" vertex="1">
          <mxGeometry x="1060" y="360" width="500" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n229" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;Model serving:&lt;/b&gt; ONE open-weight model on AMD ROCm (vLLM, OpenAI-compatible endpoint) serves both LLM calls. Orchestrated by the Agents SDK Runner. (Split into two models only if profiling justifies it.)" vertex="1">
          <mxGeometry x="300" y="470" width="760" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n230" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Everything grey/orange is deterministic&lt;/b&gt; — gate, evidence, policy, enforcement. Only 'extract' and 'estimate' are LLM. That's the whole system." vertex="1">
