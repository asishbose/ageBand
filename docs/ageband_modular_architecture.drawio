  <diagram name="6 · M6/M7 Enforcement &amp;amp; Step-up" id="t6">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1680" pageHeight="1020" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n119" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="Module M6 / M7 — Enforcement &amp;amp; Step-up" vertex="1">
          <mxGeometry x="60" y="20" width="1480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n120" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Applies proportional safety to the host assistant via MCP, or (only at high impact + high confidence) asks the user to confirm — never a silent hard-block on a guess." vertex="1">
          <mxGeometry x="60" y="52" width="1480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n121" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1290" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n122" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;verticalAlign=middle;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Input&lt;/b&gt;&lt;br&gt;Decision (from M5)" vertex="1">
          <mxGeometry x="80" y="150" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n123" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;safety_applier&lt;/b&gt; (M6)&lt;br&gt;&lt;br&gt;&amp;bull; sets, for THIS session:&lt;br&gt;&amp;nbsp; - content filter level&lt;br&gt;&amp;nbsp; - feature availability&lt;br&gt;&amp;nbsp; - tone / guardrail profile&lt;br&gt;&amp;bull; proportional · reversible&lt;br&gt;&amp;bull; MCP out: safety-control" vertex="1">
          <mxGeometry x="350" y="110" width="320" height="160" as="geometry" />
