          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e203" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#6c8ebf;dashed=1;endArrow=block;" edge="1" source="n199" target="n198" value="shared safety posture&lt;br&gt;(this/next turn)">
          <mxGeometry relative="1" as="geometry">
