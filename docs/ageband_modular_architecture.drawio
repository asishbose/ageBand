          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se_e6" edge="1" parent="1" source="se_pipeline" target="se_results" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" value="predicted band + confidence">
