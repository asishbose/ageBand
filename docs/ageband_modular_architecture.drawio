  <diagram name="4 · M3 Evidence Fabric" id="t4">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n89" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1A1A2E;" value="Module M3 — Evidence Fabric" vertex="1">
          <mxGeometry x="60" y="20" width="1380" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n90" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="Session-scoped, ephemeral accumulation of cues with corroboration and decay. The privacy core: no profile, no PII, purged at session end." vertex="1">
          <mxGeometry x="60" y="52" width="1380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n91" parent="1" style="fillColor=#f5f5f5;strokeColor=#666666;rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;font color='#333'&gt;&amp;#9472;&amp;#9472;&lt;/font&gt; sequential / handoff&lt;br&gt;&lt;font color='#d79b00'&gt;- - -&lt;/font&gt; function tool call&lt;br&gt;&lt;font color='#9673a6'&gt;- - -&lt;/font&gt; MCP call (external)&lt;br&gt;&lt;font color='#b85450'&gt;- - -&lt;/font&gt; model serving (AMD)&lt;br&gt;&lt;font color='#6c8ebf'&gt;- - -&lt;/font&gt; feedback / loop" vertex="1">
          <mxGeometry x="1100" y="30" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n92" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#2D2D44;strokeColor=#1A1A2E;fontColor=#FFFFFF;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fontSize=11;" value="&lt;b&gt;Evidence Store&lt;/b&gt;&lt;br&gt;(in-memory, session-scoped, TTL)&lt;br&gt;&lt;br&gt;EvidenceRecord {&lt;br&gt;&amp;nbsp; session_id,&lt;br&gt;&amp;nbsp; cues: [ {type, value_abstracted,&lt;br&gt;&amp;nbsp;&amp;nbsp; weight, turn, source_subagent} ],&lt;br&gt;&amp;nbsp; corroboration_score,&lt;br&gt;&amp;nbsp; last_updated }" vertex="1">
          <mxGeometry x="120" y="150" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="n93" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;update_evidence()&lt;/b&gt; tool&lt;br&gt;&lt;br&gt;&amp;bull; append this turn's cues&lt;br&gt;&amp;bull; recompute corroboration&lt;br&gt;&amp;nbsp; (agree / conflict)&lt;br&gt;&amp;bull; abstracts values (no raw PII)" vertex="1">
          <mxGeometry x="560" y="130" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n94" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;read_evidence()&lt;/b&gt; tool&lt;br&gt;&lt;br&gt;&amp;bull; return accumulated cues +&lt;br&gt;&amp;nbsp; corroboration for M4&lt;br&gt;&amp;bull; read-only snapshot" vertex="1">
          <mxGeometry x="560" y="290" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n95" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;decay()&lt;/b&gt; tool&lt;br&gt;&lt;br&gt;&amp;bull; older cues lose weight&lt;br&gt;&amp;bull; keeps estimate responsive&lt;br&gt;&amp;nbsp; to the current user&lt;br&gt;&amp;bull; runs on a schedule" vertex="1">
          <mxGeometry x="560" y="420" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n96" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Ephemerality guarantees&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; session-scoped only &amp;mdash; no cross-session identity&lt;br&gt;&amp;bull; raw cues + INFERRED band are never persisted&lt;br&gt;&amp;bull; only an explicitly CONFIRMED age (from step-up)&lt;br&gt;&amp;nbsp; may persist &amp;mdash; against an EXISTING account only&lt;br&gt;&amp;bull; values abstracted (cue TYPE, not raw quote)&lt;br&gt;&amp;bull; purged on session end / TTL expiry&lt;br&gt;&amp;bull; this is what makes it 'signal, not surveillance'" vertex="1">
          <mxGeometry x="940" y="150" width="420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n97" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Corroboration model&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; cues that agree raise the score&lt;br&gt;&amp;bull; cues that conflict lower it &amp;rarr; feeds&lt;br&gt;&amp;nbsp; ContradictionChecker in M4&lt;br&gt;&amp;bull; single ambiguous cue can't swing the band" vertex="1">
          <mxGeometry x="940" y="360" width="420" height="150" as="geometry" />
        </mxCell>
        <mxCell id="e98" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n93" target="n92" value="write">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e99" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;" edge="1" source="n92" target="n94" value="read">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e100" parent="1" style="rounded=1;html=1;strokeWidth=2;strokeColor=#333;endArrow=block;dashed=1;" edge="1" source="n95" target="n92" value="age-out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n101" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="From M2 (SignalSet)" vertex="1">
          <mxGeometry x="560" y="100" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n102" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555;" value="To M4 (evidence)" vertex="1">
          <mxGeometry x="560" y="405" width="200" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="5 · M5 Policy &amp;amp; Decision" id="t5">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1620" pageHeight="980" math="0" shadow="0">
